{
  "version": 1,
  "name": "Слив топлива",
  "description": "Критичный слив у грузовиков → Telegram и тикет",
  "enabled": true,
  "nodes": [
    {"id": "t1", "type": "fuel_drop", "position": {"x": 60, "y": 140},
     "params": {"drop_pct": 15, "window_minutes": 10}},
    {"id": "f1", "type": "filter", "position": {"x": 360, "y": 140},
     "params": {"filters": [{"field": "vehicle_type", "op": "in", "value": ["truck", "tanker"]}]}},
    {"id": "s1", "type": "severity", "position": {"x": 640, "y": 140},
     "params": {"level": "critical"}},
    {"id": "a1", "type": "notify_telegram", "position": {"x": 920, "y": 60},
     "params": {"chat_id": "-100200300", "text": "Слив топлива {{vehicle_id}}: -{{value}}%"}},
    {"id": "a2", "type": "create_ticket", "position": {"x": 920, "y": 240},
     "params": {"queue": "security", "title": "Слив топлива {{vehicle_id}}", "description": "Падение {{value}}% за 10 минут"}}
  ],
  "edges": [
    {"from": "t1", "to": "f1"},
    {"from": "f1", "to": "s1"},
    {"from": "s1", "to": "a1"},
    {"from": "s1", "to": "a2"}
  ]
}
