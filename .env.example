# UID/GID хост-пользователя для php-контейнера (docker-compose читает этот файл).
# Нужно, если каталог проекта принадлежит не uid 1000 (частый случай на сервере
# под root). Скопируйте в .env и подставьте свои значения (id -u / id -g):
#   cp .env.example .env  &&  sed -i "s/1000/$(id -u)/g" .env
APP_UID=1000
APP_GID=1000
