{
    "name": "app/fleet-telemetry-explorer",
    "description": "Learning project: ClickHouse + Honeycomb-like BubbleUp for fleet telemetry",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.3",
        "symfony/console": "^7.2",
        "symfony/dotenv": "^7.2",
        "symfony/framework-bundle": "^7.2",
        "symfony/http-client": "^7.2",
        "symfony/runtime": "^7.2",
        "symfony/twig-bundle": "^7.2",
        "symfony/uid": "^7.2",
        "symfony/yaml": "^7.2"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "symfony/runtime": true
        }
    }
}
