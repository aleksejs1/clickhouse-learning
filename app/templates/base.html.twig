<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <title>{% block title %}Fleet Telemetry Explorer{% endblock %}</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4"></script>
    {% block head %}{% endblock %}
    <style>
        * { box-sizing: border-box; }
        body { margin: 0; font: 14px/1.45 system-ui, sans-serif; color: #1e293b; background: #f8fafc; }
        header { background: #0f172a; padding: 10px 24px; }
        header a { color: #f8fafc; text-decoration: none; font-weight: 600; }
        main { padding: 16px 24px; max-width: 1500px; margin: 0 auto; }
        h1 { font-size: 20px; }
        table { border-collapse: collapse; width: 100%; background: #fff; }
        th, td { padding: 6px 10px; border-bottom: 1px solid #e2e8f0; text-align: left; white-space: nowrap; }
        th { background: #f1f5f9; position: sticky; top: 0; }
        tbody tr:hover { background: #fef3c7; cursor: pointer; }
        select { padding: 4px 8px; }
        .toolbar { display: flex; gap: 16px; align-items: center; margin: 12px 0; }
        .stats { display: flex; gap: 12px; flex-wrap: wrap; margin: 12px 0; }
        .timeline { margin: 12px 0; background: #fff; border: 1px solid #e2e8f0; padding: 10px; }
        .timeline figcaption { font-weight: 600; margin-bottom: 6px; }
        .timeline div { height: 130px; }
        .timeline canvas { cursor: crosshair; }
        .map-panel { margin: 12px 0; background: #fff; border: 1px solid #e2e8f0; padding: 10px; }
        .map-panel figcaption { font-weight: 600; margin-bottom: 6px; }
        .map-panel div { height: 380px; }
        .stat { background: #fff; border: 1px solid #e2e8f0; padding: 10px 16px; min-width: 180px; flex: 1; }
        .stat b { display: block; font-size: 22px; }
        .stat span { color: #64748b; font-size: 12px; }
        .toolbar a { color: #0369a1; }
        .muted { color: #64748b; }
        dl.event-card { display: grid; grid-template-columns: repeat(auto-fill, minmax(230px, 1fr)); gap: 2px 16px; background: #fff; border: 1px solid #e2e8f0; padding: 12px 16px; }
        dl.event-card div { display: flex; gap: 8px; padding: 2px 0; }
        dl.event-card dt { color: #64748b; min-width: 150px; margin: 0; }
        dl.event-card dd { margin: 0; font-weight: 600; }
        .charts { display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 16px; margin-top: 16px; }
        .charts figure { margin: 0; background: #fff; border: 1px solid #e2e8f0; padding: 10px; }
        .charts figcaption { font-weight: 600; margin-bottom: 6px; }
        .charts figure.anomaly { border: 2px solid #f59e0b; }
        .charts figure.anomaly figcaption::after { content: ' ← аномалия?'; color: #b45309; font-weight: 400; }
        .chart-stats summary { color: #64748b; font-size: 11px; cursor: pointer; margin-top: 6px; }
        .chart-stats pre { font-size: 11px; background: #f8fafc; border: 1px solid #e2e8f0; padding: 8px; white-space: pre-wrap; margin: 4px 0 0; }
        .rgrid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 16px; }
        .rgrid figure { margin: 0; background: #fff; border: 1px solid #e2e8f0; padding: 12px; min-width: 0; }
        .rgrid figure.w1 { grid-column: span 1; } .rgrid figure.w2 { grid-column: span 2; } .rgrid figure.w3 { grid-column: span 3; }
        .rgrid figcaption { font-weight: 600; margin-bottom: 8px; }
        .rstats { font-size: 11px; margin-top: 6px; }
        .stat-value { font-size: 34px; font-weight: 700; line-height: 1.2; }
        .stat-delta { font-size: 14px; font-weight: 600; }
        .stat-delta.up { color: #15803d; } .stat-delta.down { color: #b91c1c; }
        .rtable { font-size: 13px; } .rtable td, .rtable th { padding: 3px 8px; white-space: normal; }
        .hm td { text-align: center; font-size: 11px; padding: 2px 4px; }
    </style>
</head>
<body>
<header>
    <a href="/">Fleet Telemetry Explorer</a>
    <a href="/anomalies" style="font-weight: 400; margin-left: 20px">Аномалии</a>
    <a href="/reports" style="font-weight: 400; margin-left: 20px">Репорты</a>
</header>
<main>
{% block content %}{% endblock %}
</main>
</body>
</html>
