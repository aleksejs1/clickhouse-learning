{% extends 'base.html.twig' %}

{% set event_types = ['gps_ping', 'trip_start', 'trip_end', 'refuel', 'harsh_braking', 'speeding', 'idle', 'engine_fault'] %}

{% block content %}
<h1>События <span class="muted">({{ total }})</span></h1>

<div class="stats">
    <div class="stat">
        <b>{{ stats.rows|number_format(0, '.', ' ') }}</b>
        <span>событий в базе</span>
    </div>
    <div class="stat">
        <b>{{ stats.fields }}</b>
        <span>полей в событии: {{ stats.dimensions }} измерений + {{ stats.metrics }} метрик + id и время</span>
    </div>
    <div class="stat">
        <b>{{ stats.disk_mb|number_format(1, '.', ' ') }} МБ</b>
        <span>на диске (сжато, {{ stats.uncompressed_mb|number_format(1, '.', ' ') }} МБ без сжатия)</span>
    </div>
    <div class="stat">
        <b>≈ {{ stats.json_export_mb|number_format(1, '.', ' ') }} МБ</b>
        <span>экспорт в JSON: {{ stats.rows|number_format(0, '.', ' ') }} строк × {{ stats.avg_json_row }} Б
            {% if stats.disk_mb > 0 %}— в {{ (stats.json_export_mb / stats.disk_mb)|number_format(1) }}× больше, чем на диске{% endif %}</span>
    </div>
</div>

<figure class="timeline">
    <figcaption>События по часам{{ event_type ? ' · ' ~ event_type }} — выделите диапазон мышью, чтобы задать период</figcaption>
    <div>
        <canvas id="timeline"
                data-points="{{ timeline|json_encode }}"
                data-from="{{ time.from|default('') }}"
                data-to="{{ time.to|default('') }}"></canvas>
    </div>
</figure>

<form class="toolbar" method="get">
    <label>Тип события:
        <select name="event_type" onchange="this.form.submit()">
            <option value="">— все —</option>
            {% for t in event_types %}
                <option value="{{ t }}" {{ t == event_type ? 'selected' }}>{{ t }}</option>
            {% endfor %}
        </select>
    </label>
    <label>с <input type="datetime-local" name="from" value="{{ time.from|default('') }}"></label>
    <label>по <input type="datetime-local" name="to" value="{{ time.to|default('') }}"></label>
    <button>Применить</button>
    {% if time.from is defined or time.to is defined %}
        <a href="{{ path('app_page_index', {event_type: event_type}) }}">сбросить период</a>
    {% endif %}
    <span class="muted">страница {{ page + 1 }} из {{ max(pages, 1) }}</span>
    {% if page > 0 %}
        <a href="{{ path('app_page_index', {page: page - 1, event_type: event_type}|merge(time)) }}">← новее</a>
    {% endif %}
    {% if page + 1 < pages %}
        <a href="{{ path('app_page_index', {page: page + 1, event_type: event_type}|merge(time)) }}">старше →</a>
    {% endif %}
</form>

<table>
    <thead>
    <tr>
        <th>event_time</th><th>event_type</th><th>vehicle_id</th><th>driver_id</th>
        <th>route_id</th><th>region</th><th>speed_kmh</th><th>fuel_consumption_l100</th>
    </tr>
    </thead>
    <tbody>
    {% for e in events %}
        <tr onclick="location.href='{{ path('app_page_event', {id: e.event_id}|merge(time)) }}'">
            <td>{{ e.event_time }}</td>
            <td>{{ e.event_type }}</td>
            <td>{{ e.vehicle_id }}</td>
            <td>{{ e.driver_id }}</td>
            <td>{{ e.route_id }}</td>
            <td>{{ e.region }}</td>
            <td>{{ e.speed_kmh }}</td>
            <td>{{ e.fuel_consumption_l100 }}</td>
        </tr>
    {% else %}
        <tr><td colspan="8" class="muted">Нет данных — запустите app:generate-events</td></tr>
    {% endfor %}
    </tbody>
</table>
<script src="/app.js"></script>
{% endblock %}
