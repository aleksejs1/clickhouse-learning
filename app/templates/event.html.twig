{% extends 'base.html.twig' %}

{% block title %}{{ event.event_type }} · {{ event.event_time }}{% endblock %}

{% block head %}
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
{% endblock %}

{% block content %}
<h1>{{ event.event_type }} <span class="muted">· {{ event.event_time }} · {{ event.vehicle_id }}</span></h1>

<dl class="event-card">
    {% for key, value in event %}
        <div><dt>{{ key }}</dt><dd>{{ value }}</dd></div>
    {% endfor %}
</dl>

<div class="toolbar">
    <label>Похожие = события, где совпадает
        <select onchange="const p = new URLSearchParams(location.search); p.set('similar_by', this.value); location.search = p">
            {% for d in dimensions %}
                <option value="{{ d }}" {{ d == similar_by ? 'selected' }}>{{ d }} = {{ event[d] }}</option>
            {% endfor %}
        </select>
    </label>
    <label>сэмпл
        <select onchange="const p = new URLSearchParams(location.search); this.value ? p.set('sample', this.value) : p.delete('sample'); location.search = p">
            <option value="">100%</option>
            <option value="0.1" {{ sample == '0.1' ? 'selected' }}>10%</option>
            <option value="0.01" {{ sample == '0.01' ? 'selected' }}>1%</option>
        </select>
    </label>
    <span class="muted">
        <span style="color:#b45309">■</span> похожие ({{ similar_by }} = {{ event[similar_by] }})
        &nbsp;<span style="color:#5b8cc4">■</span> все остальные
        {% if time.from is defined or time.to is defined %}
            &nbsp;·&nbsp; период: {{ time.from|default('…') }} — {{ time.to|default('…') }}
            (<a href="{{ path('app_page_event', {id: event.event_id, similar_by: similar_by}) }}">сбросить</a>)
        {% endif %}
    </span>
</div>

<figure class="map-panel">
    <figcaption>География групп
        <span class="muted" style="font-weight: 400">· ячейки ~1 км: янтарные — где «похожие» перепредставлены, синие — обычные; маркер — это событие</span>
    </figcaption>
    <div id="map"
         data-similar-by="{{ similar_by }}"
         data-similar-value="{{ event[similar_by] }}"
         data-from="{{ time.from|default('') }}"
         data-to="{{ time.to|default('') }}"
         data-sample="{{ sample }}"
         data-lat="{{ event.lat }}"
         data-lon="{{ event.lon }}"></div>
</figure>

<div class="charts" id="charts"
     data-similar-by="{{ similar_by }}"
     data-similar-value="{{ event[similar_by] }}"
     data-from="{{ time.from|default('') }}"
     data-to="{{ time.to|default('') }}"
     data-sample="{{ sample }}"
     data-fields="{{ chart_fields|join(',') }}">
    {% for field in chart_fields %}
        <figure>
            <figcaption>{{ field }}</figcaption>
            <canvas id="chart-{{ field }}"></canvas>
        </figure>
    {% endfor %}
</div>

<script src="/app.js"></script>
{% endblock %}
